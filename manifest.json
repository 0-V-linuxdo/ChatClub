{
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "name": "ChatClub",
  "short_name": "ChatClub",
  "description": "__MSG_extension_description__",
  "default_locale": "zh_CN",
  "version": "2026.7.15",
  "version_name": "「2026-07-15｜19:31:33」",
  "homepage_url": "https://chatclub.local/",
  "action": {
    "default_title": "ChatClub",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": [
      "background/firefox-background.js"
    ],
    "service_worker": "background/service-worker.js",
    "preferred_environment": [
      "document",
      "service_worker"
    ],
    "type": "module"
  },
  "options_page": "chatClub.html",
  "permissions": [
    "storage",
    "cookies",
    "declarativeNetRequest",
    "scripting",
    "webNavigation",
    "debugger",
    "favicon",
    "tabs",
    "unlimitedStorage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "optional_permissions": [
    "userScripts"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "resources": [
        "content/preload.js",
        "content/message-navigator.js",
        "content/content.js",
        "content/summary-userscripts.js",
        "content/summary-userscripts-main.js",
        "topic-delete-userscripts/*"
      ],
      "use_dynamic_url": false
    }
  ]
}

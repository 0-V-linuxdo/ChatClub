{
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "name": "ChatClub",
  "short_name": "ChatClub",
  "description": "__MSG_extension_description__",
  "default_locale": "zh_CN",
  "version": "2026.7.17.9",
  "version_name": "「2026-07-17｜23:22:14」",
  "homepage_url": "https://github.com/0-V-linuxdo/ChatClub",
  "action": {
    "default_title": "ChatClub",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": [
      "background/firefox-background.js"
    ],
    "service_worker": "background/service-worker.js",
    "preferred_environment": [
      "document",
      "service_worker"
    ],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "cookies",
    "declarativeNetRequest",
    "scripting",
    "webNavigation",
    "debugger",
    "favicon",
    "tabs",
    "unlimitedStorage",
    "clipboardRead",
    "clipboardWrite"
  ],
  "optional_permissions": [
    "userScripts"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
